FROM runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04

WORKDIR /workspace

# Install uv
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:$PATH"

# Pre-install dependencies so pod startup is fast.
# Only the lockfile + pyproject are needed — no source code baked in.
COPY pyproject.toml uv.lock* ./
RUN uv venv && uv sync --extra gpu --no-install-project || true

# git is pre-installed on RunPod base images, but ensure it's there
RUN apt-get update && apt-get install -y --no-install-recommends git && rm -rf /var/lib/apt/lists/*
